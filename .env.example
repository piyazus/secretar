# ==== LLM ====
ANTHROPIC_API_KEY=
LLM_COMPLEX_MODEL=claude-sonnet-5
LLM_ROUTING_MODEL=claude-haiku-4-5-20251001

# ==== Google OAuth (Calendar + Gmail) ====
# Project: secretar-fund (console.cloud.google.com/auth/overview?project=secretar-fund)
GOOGLE_CLIENT_ID=378168294049-r085s0ma7q1an6caec1npsad7crtc5so.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.secretarchik.online/api/auth/callback/google

# ==== Владелец ====
# Единственный аккаунт, которому разрешён вход в веб-чат (NextAuth) и чьи
# календарь/почта управляются. Должен быть в test users OAuth consent screen.
OWNER_EMAIL=
# Часовой пояс владельца (для расписания и распознавания дат)
TIMEZONE=Asia/Almaty

# ==== PostgreSQL (self-hosted) ====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secretar
POSTGRES_USER=secretar
POSTGRES_PASSWORD=

# ==== n8n ====
N8N_HOST=n8n.ВАШ-ДОМЕН.kz
N8N_PORT=5678
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
# Куда фронтенд шлёт команды чата (webhook из n8n/router.json)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/chat

# ==== Внутренний API ====
# Токен для вызовов n8n -> frontend /api/agent (внутри docker-сети).
# Сгенерировать: openssl rand -hex 24
INTERNAL_API_TOKEN=

# ==== faster-whisper (self-hosted voice) ====
# fedirz/faster-whisper-server слушает порт 8000 (OpenAI-совместимый API)
WHISPER_ENDPOINT=http://faster-whisper:8000
WHISPER_MODEL=medium

# ==== Cloudflare Tunnel ====
# Токен из Zero Trust -> Networks -> Tunnels -> <tunnel> -> Install connector.
# Ingress в дашборде: app.<домен> -> http://frontend:3000, n8n.<домен> -> http://n8n:5678
TUNNEL_TOKEN=

# ==== Domain ====
# Публичный домен, подключённый к Cloudflare (без него у туннеля нет постоянного адреса).
DOMAIN=app.secretarchik.online
ACME_EMAIL=baitulenov_d@fmalm.nis.edu.kz

# ==== Telegram ====
TELEGRAM_BOT_TOKEN=

# ==== App ====
NODE_ENV=production
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://app.secretarchik.online
