# ==== LLM ====
ANTHROPIC_API_KEY=
LLM_COMPLEX_MODEL=claude-sonnet-5
LLM_ROUTING_MODEL=claude-haiku-4-5-20251001

# ==== Google OAuth (Calendar + Gmail) ====
# Проект: secretar-friend (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.ВАШ-ДОМЕН/api/auth/callback/google

# ==== PostgreSQL (self-hosted) ====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secretar
POSTGRES_USER=secretar
POSTGRES_PASSWORD=

# ==== n8n ====
N8N_HOST=n8n.ВАШ-ДОМЕН
N8N_PORT=5678
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ==== faster-whisper (self-hosted voice) ====
WHISPER_ENDPOINT=http://faster-whisper:9000
WHISPER_MODEL=medium

# ==== Cloudflare Tunnel ====
# Токен: Zero Trust -> Networks -> Connectors -> <tunnel> -> Install connector
TUNNEL_TOKEN=

# ==== Telegram ====
TELEGRAM_BOT_TOKEN=

# ==== Domain ====
DOMAIN=app.ВАШ-ДОМЕН
ACME_EMAIL=

# ==== App ====
NODE_ENV=production
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://app.ВАШ-ДОМЕН
